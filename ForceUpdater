local function EJKQ_fake_script() -- ForceUpdatingBanner.LocalScript 
	local script = Instance.new('LocalScript', ForceUpdatingBanner)

	-- Update Forcing --
	
	if game.CoreGui:FindFirstChild("VegaXAndroidUI") then
		game.CoreGui:FindFirstChild("VegaXAndroidUI"):Destroy()
	end
	
	
	script.Parent.CopyWebsiteURL.MouseButton1Click:connect(function()
		setclipboard("https://vegax.gg")
		script.Parent.Visible = false
		game.Players.LocalPlayer:Kick("请访问 Vega X 网站继续使用 Vega X，谢谢。\nPlease visit the Vega X website to continue using Vega X, thank you.")
	end)
end
coroutine.wrap(EJKQ_fake_script)()
